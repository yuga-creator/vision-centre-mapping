# ==============================================================================
# Vision Centre Mapping Frontend - Environment Template
# Copy this file to `.env` in the root of the frontend folder.
# ==============================================================================

# Application environment configuration
APP_ENV=development

# Custom API integrations (if any)
OSRM_ROUTER_URL=https://router.project-osrm.org/route/v1/driving/
MAP_TILE_PROVIDER_URL=https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}.png
MAP_USER_AGENT_PACKAGE=com.example.eye_app
