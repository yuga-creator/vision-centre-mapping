rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Rules for the "centers" collection
    match /centers/{centerId} {
      
      // 1. PUBLIC READ ACCESS
      // Anyone can query the database to locate centers near them.
      allow read: if true;

      // 2. ADMIN WRITE/DELETE ACCESS
      // In production, we restrict write and delete permissions to authenticated administrative users.
      // (Note: To implement this, you must configure Firebase Auth in the frontend and admin uploader).
      allow write, delete: if request.auth != null;
      
      // DEVELOPMENT BYPASS (Alternative)
      // Un-comment the line below to permit unauthenticated additions/removals during development only.
      // allow write, delete: if true;
    }
  }
}
